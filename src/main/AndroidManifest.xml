<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="true"
        android:label="Hospital App"
        android:theme="@style/Theme.AppCompat.Light.NoActionBar">

        <!-- Activities -->
        <activity android:name=".AdminActivity"
            android:exported="false" />
        <activity android:name=".AdminDashboard"
            android:exported="false" />
        <activity android:name=".RequestActivity"
            android:exported="false" />
        <activity android:name=".RegisterActivity"
            android:exported="false" />
        <activity android:name=".LoginActivity"
            android:exported="false" />
        <activity android:name=".RemoveActivity"
            android:exported="false" />
        <activity android:name=".DeleteUserActivity"
            android:exported="false" />
        <activity android:name=".ViewRequest"
            android:exported="false" />
        <activity android:name=".AddServiceActivity"
            android:exported="false" />

        <!-- Launcher Activity -->
        <activity android:name=".SplashActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

    </application>

</manifest>
